# -----------------------------------------------
# DATA FILES — Do not commit raw microdata
# -----------------------------------------------
data/*.dta
data/*.csv
data/*.sav
data/*.xlsx
data/*.xls

# -----------------------------------------------
# STATA working files
# -----------------------------------------------
*.stswp
*.smcl
*.log
*.ster

# -----------------------------------------------
# OS and editor clutter
# -----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.tmp
*~

# -----------------------------------------------
# R (if used alongside Stata)
# -----------------------------------------------
.Rhistory
.RData
.Rproj.user/

# -----------------------------------------------
# Python (if used)
# -----------------------------------------------
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# -----------------------------------------------
# Large output files (keep PNGs, skip raw exports)
# -----------------------------------------------
outputs/*.dta
outputs/*.csv
